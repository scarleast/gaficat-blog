---
// Footer - site footer with copyright, beian, hosting credit, and powered-by
---

<footer class="border-t border-[var(--color-border)] dark:border-[var(--color-border-dark)] bg-[var(--color-bg-card)] dark:bg-[var(--color-bg-card-dark)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col items-center gap-4">
      <!-- Top row: copyright + hosting -->
      <div class="flex flex-col sm:flex-row items-center justify-between w-full gap-4">
        <!-- Copyright -->
        <div class="text-sm text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]">
          &copy; 2019&ndash;2026 加菲猫的创客工坊
        </div>

        <!-- Right side: hosting + powered by -->
        <div class="flex items-center gap-4">
          <!-- 又拍云 logo -->
          <a
            href="https://www.upyun.com/?utm_source=lianmeng&utm_medium=referral"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center opacity-70 hover:opacity-100 transition-opacity"
            aria-label="又拍云提供CDN加速"
          >
            <img
              src="/img/upyun_logo4.png"
              alt="又拍云"
              class="h-5 w-auto"
              loading="lazy"
            />
          </a>

          <!-- Divider -->
          <span class="text-[var(--color-border)] dark:text-[var(--color-border-dark)]">|</span>

          <!-- Powered by -->
          <span class="text-xs text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]">
            Powered by <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">Astro</a>
          </span>
        </div>
      </div>

      <!-- Bottom row: beian info -->
      <div class="flex flex-col sm:flex-row items-center gap-2 text-xs text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]">
        <a href="https://beian.miit.gov.cn/" target="_blank" rel="nofollow noopener" class="hover:text-[var(--color-accent)] transition-colors">
          陕ICP备18017214号-1
        </a>
        <span class="hidden sm:inline">|</span>
        <a href="http://www.beian.gov.cn/portal/registerSystemInfo?recordcode=61019002003129" target="_blank" rel="nofollow noopener" class="hover:text-[var(--color-accent)] transition-colors">
          陕公网安备61019002003129号
        </a>
      </div>
    </div>
  </div>
</footer>
