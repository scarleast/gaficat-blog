---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/archives', label: '归档' },
  { href: '/categories', label: '分类' },
  { href: '/tags', label: '标签' },
  { href: '/aboutme', label: '关于' },
  { href: '/links', label: '友链' },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<header
  id="site-header"
  class:list={[
    'fixed top-0 left-0 right-0 z-40 transition-all duration-300',
    isHome
      ? 'bg-transparent header-transparent'
      : 'bg-[var(--color-bg-nav)] dark:bg-[var(--color-bg-nav-dark)] shadow-sm',
  ]}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Site title -->
      <a
        href="/"
        class="flex items-center gap-2 text-white font-semibold text-lg tracking-wide hover:opacity-90 transition-opacity shrink-0"
      >
        <span class="hidden sm:inline">加菲猫的创客工坊</span>
        <span class="sm:hidden">加菲猫</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href ||
            (link.href !== '/' && currentPath.startsWith(link.href.replace(/\/$/, '')));
          return (
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 rounded-md text-sm font-medium transition-colors',
                isActive
                  ? 'text-white bg-white/15'
                  : 'text-white/75 hover:text-white hover:bg-white/10',
              ]}
            >
              {link.label}
            </a>
          );
        })}
      </nav>

      <!-- Right side: search + theme toggle + mobile menu button -->
      <div class="flex items-center gap-2">
        <!-- Search button -->
        <button
          id="search-btn"
          type="button"
          aria-label="搜索"
          class="p-2 rounded-lg text-white/80 hover:text-white hover:bg-white/10 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>

        <ThemeToggle />

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="打开菜单"
          class="md:hidden p-2 rounded-lg text-white/80 hover:text-white hover:bg-white/10 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"
        >
          <!-- Hamburger icon -->
          <svg id="hamburger-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close icon -->
          <svg id="close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu dropdown -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-[var(--color-bg-nav)] dark:bg-[var(--color-bg-nav-dark)] border-t border-white/10"
  >
    <nav class="px-4 py-3 space-y-1">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href ||
          (link.href !== '/' && currentPath.startsWith(link.href.replace(/\/$/, '')));
        return (
          <a
            href={link.href}
            class:list={[
              'block px-3 py-2.5 rounded-md text-sm font-medium transition-colors',
              isActive
                ? 'text-white bg-white/15'
                : 'text-white/75 hover:text-white hover:bg-white/10',
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  function initMobileMenu() {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!menuBtn || !mobileMenu || !hamburgerIcon || !closeIcon) return;

    let isOpen = false;

    function toggleMenu() {
      isOpen = !isOpen;
      mobileMenu.classList.toggle('hidden', !isOpen);
      hamburgerIcon.classList.toggle('hidden', isOpen);
      closeIcon.classList.toggle('hidden', !isOpen);
      menuBtn.setAttribute('aria-label', isOpen ? '关闭菜单' : '打开菜单');
    }

    menuBtn.addEventListener('click', toggleMenu);

    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });

    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) toggleMenu();
    });
  }

  function initSearchButton() {
    const searchBtn = document.getElementById('search-btn');
    if (!searchBtn) return;
    searchBtn.addEventListener('click', () => {
      const modal = document.getElementById('search-modal');
      if (modal) {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        const input = document.getElementById('search-input') as HTMLInputElement;
        if (input) setTimeout(() => input.focus(), 100);
      }
    });
  }

  function initHeaderScroll() {
    const header = document.getElementById('site-header');
    if (!header || !header.classList.contains('header-transparent')) return;

    function onScroll() {
      if (window.scrollY > 60) {
        header.classList.add('bg-[var(--color-bg-nav)]', 'shadow-sm');
        header.classList.remove('bg-transparent');
      } else {
        header.classList.remove('bg-[var(--color-bg-nav)]', 'shadow-sm');
        header.classList.add('bg-transparent');
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  initMobileMenu();
  initSearchButton();
  initHeaderScroll();
  document.addEventListener('astro:after-swap', () => {
    initMobileMenu();
    initSearchButton();
    initHeaderScroll();
  });
</script>
