---
interface Props {
  post: {
    data: {
      title: string;
      date: Date;
      abbrlink: string;
      tags: string[];
      categories: string[] | string[][] | string;
      excerpt?: string;
      sticky?: number;
    };
    body?: string;
  };
}

const { post } = Astro.props;
const { title, date, abbrlink, tags, sticky } = post.data;

// Generate excerpt: use frontmatter excerpt or extract from body
function getExcerpt(excerpt?: string, body?: string): string {
  if (excerpt) return excerpt;
  if (!body) return '';
  // Strip markdown/frontmatter/HTML, get first ~120 chars of plain text
  const text = body
    .replace(/^---[\s\S]*?---/, '') // remove frontmatter
    .replace(/<[^>]*>/g, '')         // remove HTML tags
    .replace(/!\[[^\]]*\]\([^)]*\)/g, '') // remove images
    .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1') // links → text
    .replace(/#{1,6}\s/g, '')        // remove headings
    .replace(/```[\s\S]*?```/g, '')   // remove code blocks
    .replace(/`[^`]*`/g, '')          // remove inline code
    .replace(/\{\/\*[\s\S]*?\*\/\}/g, '') // remove MDX comments
    .replace(/<AudioPlayer[^>]*\/>/g, '')
    .replace(/<VideoPlayer[^>]*\/>/g, '')
    .replace(/<Bilibili[^>]*\/>/g, '')
    .replace(/import\s.*from.*/g, '')
    .replace(/\{?\s*\.\.\..*/g, '')
    .replace(/[*_~>|]/g, '')          // remove markdown chars
    .replace(/\n+/g, ' ')             // newlines → spaces
    .trim();
  return text.length > 120 ? text.slice(0, 120) + '...' : text;
}

const excerpt = getExcerpt(post.data.excerpt, post.body);

// Normalize categories for display
function getCategories(cat: string[] | string[][] | string): string[] {
  if (typeof cat === 'string') return [cat];
  if (Array.isArray(cat) && cat.length > 0) {
    if (Array.isArray(cat[0])) return (cat as string[][]).map(c => c.join('/'));
    return cat as string[];
  }
  return [];
}

const categories = getCategories(post.data.categories);
const formattedDate = date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-');
---

<article class="post-card py-6">
  <a href={`/posts/${abbrlink}.html`} class="post-card-link group block">
    <!-- Sticky badge -->
    {sticky && (
      <span class="inline-block px-2 py-0.5 text-xs rounded bg-[var(--color-accent)] text-white mb-2">置顶</span>
    )}

    <!-- Title -->
    <h2 class="text-xl font-semibold text-[var(--color-text-heading)] dark:text-[var(--color-text-heading-dark)] group-hover:text-[var(--color-text-link-hover)] dark:group-hover:text-[var(--color-accent-hover)] transition-colors mb-2 leading-snug">
      {title}
    </h2>

    <!-- Excerpt -->
    {excerpt && (
      <p class="text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)] text-sm leading-relaxed mb-3 line-clamp-2">
        {excerpt}
      </p>
    )}

    <!-- Meta row: date | categories | tags -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]">
      <!-- Date -->
      <span class="inline-flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
        </svg>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </span>

      <!-- Categories -->
      {categories.length > 0 && (
        <span class="inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
          </svg>
          {categories.map((cat, i) => (
            <a
              href={`/categories/${encodeURIComponent(cat)}.html`}
              class="hover:text-[var(--color-accent)] transition-colors"
            >{cat}</a>
          ))}
        </span>
      )}

      <!-- Tags -->
      {tags.length > 0 && (
        <span class="inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" />
          </svg>
          {tags.map((tag) => (
            <a
              href={`/tags/${encodeURIComponent(tag)}.html`}
              class="hover:text-[var(--color-accent)] transition-colors"
            >#{tag}</a>
          ))}
        </span>
      )}
    </div>
  </a>
</article>
