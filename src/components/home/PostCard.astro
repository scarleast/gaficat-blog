---
interface Props {
  post: {
    data: {
      title: string;
      date: Date;
      abbrlink: string;
      tags: string[];
      categories: string[] | string[][] | string;
      excerpt?: string;
      sticky?: number;
    };
    body?: string;
  };
}

const { post } = Astro.props;
const { title, date, abbrlink, tags, sticky } = post.data;

// Generate excerpt
function getExcerpt(excerpt?: string, body?: string): string {
  if (excerpt) return excerpt;
  if (!body) return '';
  const text = body
    .replace(/^---[\s\S]*?---/, '')
    .replace(/<[^>]*>/g, '')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
    .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
    .replace(/#{1,6}\s/g, '')
    .replace(/```[\s\S]*?```/g, '')
    .replace(/`[^`]*`/g, '')
    .replace(/\{\/\*[\s\S]*?\*\/\}/g, '')
    .replace(/<AudioPlayer[^>]*\/>/g, '')
    .replace(/<VideoPlayer[^>]*\/>/g, '')
    .replace(/<Bilibili[^>]*\/>/g, '')
    .replace(/import\s.*from.*/g, '')
    .replace(/\{?\s*\.\.\..*/g, '')
    .replace(/[*_~>|]/g, '')
    .replace(/\n+/g, ' ')
    .trim();
  return text.length > 200 ? text.slice(0, 200) + '...' : text;
}

const excerpt = getExcerpt(post.data.excerpt, post.body);

// Normalize categories
function getCategories(cat: string[] | string[][] | string): string[] {
  if (typeof cat === 'string') return [cat];
  if (Array.isArray(cat) && cat.length > 0) {
    if (Array.isArray(cat[0])) return (cat as string[][]).map(c => c.join('/'));
    return cat as string[];
  }
  return [];
}

const categories = getCategories(post.data.categories);
const formattedDate = date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-');
---

<!-- Index card — matching halo-theme-fluid index.html row structure -->
<div class="row mx-auto index-card">
  <article class="col-12 col-md-12 mx-auto index-info">
    <!-- Title -->
    <h2 class="index-header">
      {sticky && (
        <span class="index-pin" title="置顶">📌</span>
      )}
      <a href={`/posts/${abbrlink}.html`}>{title}</a>
    </h2>

    <!-- Excerpt — matching Fluid: index-excerpt with line clamp -->
    {excerpt && (
      <a class="index-excerpt" href={`/posts/${abbrlink}.html`}>
        <div>{excerpt}</div>
      </a>
    )}

    <!-- Meta row — matching Fluid: index-btm post-metas -->
    <div class="index-btm post-metas">
      <div class="post-meta mr-3">
        <time datetime={date.toISOString().split('T')[0]}>{formattedDate}</time>
      </div>
      {categories.length > 0 && (
        <div class="post-meta post-meta-taxonomy mr-3">
          <svg class="post-meta-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M10 4l2 2h8a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2L2 6a2 2 0 012-2h6zm10 6H4v8h16v-8z" />
          </svg>
          <span class="category-chains">
            {categories.map((cat) => (
              <span class="category-chain">
                <a href={`/categories/${encodeURIComponent(cat)}.html`} class="category-chain-item">{cat}</a>
              </span>
            ))}
          </span>
        </div>
      )}
      {tags.length > 0 && (
        <div class="post-meta">
          {tags.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag)}.html`}>#{tag}</a>
          ))}
        </div>
      )}
    </div>
  </article>
</div>
