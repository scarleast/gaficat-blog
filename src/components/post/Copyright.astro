---
// Copyright notice - shown at bottom of posts with CC BY-NC-ND 4.0 license
const siteUrl = 'https://www.gaficat.com';
const postUrl = `${siteUrl}${Astro.url.pathname}`;
---

<div class="mt-10 p-5 rounded-lg bg-[var(--color-bg)] dark:bg-[var(--color-bg-dark)] border border-[var(--color-border)] dark:border-[var(--color-border-dark)] text-sm leading-relaxed">
  <div class="flex items-start gap-3">
    <!-- CC icon -->
    <svg class="w-6 h-6 shrink-0 mt-0.5 text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-7h2v2h-2zm0-6h2v4h-2z" />
    </svg>

    <div class="space-y-1.5">
      <p class="font-medium text-[var(--color-text-heading)] dark:text-[var(--color-text-heading-dark)]">
        版权声明
      </p>
      <p class="text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]">
        本文作者：<span class="font-medium text-[var(--color-text)] dark:text-[var(--color-text-dark)]">scarleast</span>
      </p>
      <p class="text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]">
        本文链接：<a href={postUrl} class="break-all hover:text-[var(--color-accent)] transition-colors">{postUrl}</a>
      </p>
      <p class="text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]">
        本作品采用
        <a
          href="https://creativecommons.org/licenses/by-nc-nd/4.0/deed.zh"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium hover:text-[var(--color-accent)] transition-colors"
        >
          知识共享署名-非商业性使用-禁止演绎 4.0 国际许可协议
        </a>
        进行许可。
      </p>
    </div>
  </div>
</div>
