---
import BaseLayout from '../../themes/fluid-astro/layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到" description="页面不存在">
  <div class="flex flex-col items-center justify-center min-h-[60vh] px-4">
    <h1 class="text-8xl font-bold text-[var(--color-text-link-hover)] mb-4">404</h1>
    <p class="text-xl text-[var(--color-text-secondary)] mb-8">
      页面未找到，可能已被移动或删除
    </p>
    <a
      href="/"
      class="px-6 py-3 rounded bg-[var(--color-button-bg)] text-[var(--color-text-primary)] hover:text-[var(--color-text-link-hover)] hover:bg-[var(--color-button-hover-bg)] transition-colors"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
