---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/home/PostCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const categoryMap = new Map<string, typeof allPosts>();

  function getCategories(cat: string[] | string[][] | string): string[] {
    if (typeof cat === 'string') return [cat];
    if (Array.isArray(cat) && cat.length > 0) {
      if (Array.isArray(cat[0])) return (cat as string[][]).map(c => c.join('/'));
      return cat as string[];
    }
    return [];
  }

  allPosts.forEach((post) => {
    getCategories(post.data.categories).forEach((cat) => {
      if (!categoryMap.has(cat)) categoryMap.set(cat, []);
      categoryMap.get(cat)!.push(post);
    });
  });

  return [...categoryMap.entries()].map(([cat, posts]) => ({
    params: { slug: cat },
    props: { category: cat, posts: posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()) },
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`分类：${category}`} description={`分类 "${category}" 下的所有文章`}>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-8">
      <a href="/categories.html" class="text-sm text-[var(--color-accent)] hover:underline mb-2 inline-block">← 所有分类</a>
      <h1 class="text-3xl font-bold text-[var(--color-text-heading)] dark:text-[var(--color-text-heading-dark)]">
        分类：{category}
      </h1>
      <p class="text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)] mt-2">
        共 {posts.length} 篇文章
      </p>
    </div>

    <div class="grid gap-6">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </main>
</BaseLayout>
