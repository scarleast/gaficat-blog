---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts');

// Normalize categories and collect counts
const categoryMap = new Map<string, number>();

function getCategories(cat: string[] | string[][] | string): string[] {
  if (typeof cat === 'string') return [cat];
  if (Array.isArray(cat) && cat.length > 0) {
    if (Array.isArray(cat[0])) return (cat as string[][]).map(c => c.join('/'));
    return cat as string[];
  }
  return [];
}

allPosts.forEach((post) => {
  getCategories(post.data.categories).forEach((cat) => {
    categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
  });
});

const categories = [...categoryMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="分类" description="所有文章分类">
  <main class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-[var(--color-text-heading)] dark:text-[var(--color-text-heading-dark)] mb-8">分类</h1>

    <div class="grid gap-4">
      {categories.map(([cat, count]) => (
        <a
          href={`/categories/${cat}.html`}
          class="flex items-center justify-between p-4 rounded-lg bg-[var(--color-bg-card)] dark:bg-[var(--color-bg-card-dark)] border border-[var(--color-border)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent)] transition-colors"
        >
          <span class="text-[var(--color-text)] dark:text-[var(--color-text-dark)] font-medium">{cat}</span>
          <span class="text-sm text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]">{count} 篇</span>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
