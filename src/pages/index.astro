---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/home/PostCard.astro';

const POSTS_PER_PAGE = 10;

const allPosts = (await getCollection('posts'))
  .sort((a, b) => {
    // Sticky posts first
    const stickyDiff = (b.data.sticky ?? 0) - (a.data.sticky ?? 0);
    if (stickyDiff !== 0) return stickyDiff;
    return b.data.date.valueOf() - a.data.date.valueOf();
  });

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout title="加菲猫的创客工坊" description="分享各种电子设计DIY、物联网DIY、读书笔记、生活想法、流行钢琴、工作踩坑">
  <!-- Hero Banner -->
  <section class="hero-banner relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg-nav)] via-[var(--color-bg-nav)] to-[color-mix(in_srgb,var(--color-bg-nav)_80%,transparent)]"></div>
    <div class="relative max-w-3xl mx-auto text-center py-28 sm:py-36 px-4">
      <h1 class="text-3xl sm:text-5xl font-bold text-white mb-4 tracking-wide">加菲猫的创客工坊</h1>
      <p class="text-white/70 text-base sm:text-lg mb-6">今天有什么好的想法呢？</p>
      <div id="hitokoto" class="text-white/50 text-sm italic min-h-[1.5em]">
        加载中...
      </div>
    </div>
    <!-- Wave divider -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
        <path d="M0 60V30C240 5 480 5 720 30C960 55 1200 55 1440 30V60H0Z" class="fill-[var(--color-bg)] dark:fill-[var(--color-bg-dark)]" />
      </svg>
    </div>
  </section>

  <!-- Post List -->
  <main class="max-w-3xl mx-auto px-4 pb-12">
    <div class="divide-y divide-[var(--color-border)] dark:divide-[var(--color-border-dark)]">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <nav class="flex justify-center items-center gap-4 mt-12">
        <span class="text-sm text-[var(--color-text-secondary)] dark:text-[var(--color-text-secondary-dark)]">
          第 1 页 / 共 {totalPages} 页
        </span>
        <a
          href="/page/2.html"
          class="px-4 py-2 rounded-lg bg-[var(--color-primary)] dark:bg-[var(--color-primary-light)] text-white text-sm hover:opacity-90 transition-opacity"
        >
          下一页 →
        </a>
      </nav>
    )}
  </main>
</BaseLayout>

<style>
  .hero-banner {
    margin-top: -4rem;
    padding-top: 4rem;
  }
</style>

<script>
  // Hitokoto - random quote
  fetch('https://v1.hitokoto.cn/?c=a&c=b&c=d&c=i&c=k')
    .then(res => res.json())
    .then(data => {
      const el = document.getElementById('hitokoto');
      if (el) {
        const from = data.from_who ? `—— ${data.from_who}` : (data.from ? `—— 《${data.from}》` : '');
        el.textContent = `「${data.hitokoto}」${from}`;
      }
    })
    .catch(() => {
      const el = document.getElementById('hitokoto');
      if (el) el.textContent = '';
    });
</script>
