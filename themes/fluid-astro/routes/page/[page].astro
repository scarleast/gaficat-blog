---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/home/PostCard.astro';
import { fluidBannerStyle, fluidMaskStyle, fluidThemeConfig } from '../../config.mjs';

export async function getStaticPaths() {
  const POSTS_PER_PAGE = fluidThemeConfig.index.per_page;
  const allPosts = (await getCollection('posts'))
    .sort((a, b) => {
      const stickyDiff = (b.data.sticky ?? 0) - (a.data.sticky ?? 0);
      if (stickyDiff !== 0) return stickyDiff;
      return b.data.date.valueOf() - a.data.date.valueOf();
    });

  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
  const paths = [];

  for (let i = 2; i <= totalPages; i++) {
    paths.push({
      params: { page: String(i) },
      props: {
        posts: allPosts.slice((i - 1) * POSTS_PER_PAGE, i * POSTS_PER_PAGE),
        currentPage: i,
        totalPages,
      },
    });
  }

  return paths;
}

const { posts, currentPage, totalPages } = Astro.props;

// Generate page numbers for pagination
function getPageNumbers(current: number, total: number): (number | '...')[] {
  const pages: (number | '...')[] = [];
  if (total <= 7) {
    for (let i = 1; i <= total; i++) pages.push(i);
  } else {
    pages.push(1);
    if (current > 3) pages.push('...');
    for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
      pages.push(i);
    }
    if (current < total - 2) pages.push('...');
    pages.push(total);
  }
  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
---

<BaseLayout title={`第 ${currentPage} 页 - ${fluidThemeConfig.site.title}`} description={fluidThemeConfig.site.description}>
  <!-- Banner — matching halo-theme-fluid banner -->
  <div class="header-inner" style={`height: ${fluidThemeConfig.banner.index_height};`}>
    <div id="banner" class="banner" style={fluidBannerStyle()} parallax={String(fluidThemeConfig.banner.parallax)}>
      <div class="full-bg-img">
        <div class="mask flex-center" style={fluidMaskStyle()}>
          <div class="banner-text text-center fade-in-up">
            <div class="h2" style="font-size: 32px; font-weight: 500; color: #fff; line-height: 1.2;">
              <span>{fluidThemeConfig.index.slogan.text}</span>
            </div>
          </div>
          <div class="scroll-down-bar">
            <i class="iconfont icon-arrowdown">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 5v14M19 12l-7 7-7-7"/>
              </svg>
            </i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Post List — matching halo-theme-fluid index structure -->
  <main>
    <div class="container nopadding-x-md">
      <div id="board" style="margin-top: 0">
        <div class="container">
          <div class="row">
            <div class="col-12 col-md-10 m-auto">
              {posts.map((post: any) => (
                <PostCard post={post} />
              ))}

              <!-- Pagination — matching halo-theme-fluid paginator -->
              {totalPages > 1 && (
                <nav class="pagination" aria-label="文章分页">
                  {currentPage > 1 && (
                    <a
                      class="extend prev"
                      rel="prev"
                      href={currentPage === 2 ? '/' : `/page/${currentPage - 1}`}
                    >‹</a>
                  )}
                  {pageNumbers.map((page) => (
                    page === '...' ? (
                      <span class="space">…</span>
                    ) : page === currentPage ? (
                      <span class="current">{page}</span>
                    ) : (
                      <a class="page-number" href={page === 1 ? '/' : `/page/${page}`}>{page}</a>
                    )
                  ))}
                  {currentPage < totalPages && (
                    <a class="extend next" rel="next" href={`/page/${currentPage + 1}`}>›</a>
                  )}
                </nav>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  // Banner parallax
  function initParallax() {
    const banner = document.getElementById('banner');
    if (!banner || banner.getAttribute('parallax') !== 'true') return;
    const board = document.getElementById('board');
    if (!board) return;

    function onScroll() {
      const marginTop = parseInt(getComputedStyle(board).marginTop, 10) || 0;
      const maxOffset = 96 + marginTop;
      const offset = Math.min(window.scrollY / 5, maxOffset);
      banner.style.transform = `translate3d(0, ${offset}px, 0)`;
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  initParallax();

  // Scroll down arrow click
  function initScrollDownArrow() {
    const scrollDownBar = document.querySelector('.scroll-down-bar');
    if (scrollDownBar) {
      scrollDownBar.addEventListener('click', () => {
        const banner = document.getElementById('banner');
        if (banner) {
          window.scrollTo({ top: banner.offsetHeight, behavior: 'smooth' });
        }
      });
    }
  }

  initScrollDownArrow();
</script>
