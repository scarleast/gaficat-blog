---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/home/PostCard.astro';
import { fluidBannerStyle, fluidMaskStyle, fluidThemeConfig } from '../config.mjs';

const POSTS_PER_PAGE = fluidThemeConfig.index.per_page;

const allPosts = (await getCollection('posts'))
  .sort((a, b) => {
    // Sticky posts first
    const stickyDiff = (b.data.sticky ?? 0) - (a.data.sticky ?? 0);
    if (stickyDiff !== 0) return stickyDiff;
    return b.data.date.valueOf() - a.data.date.valueOf();
  });

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const currentPage = 1;
const posts = allPosts.slice(0, POSTS_PER_PAGE);

// Generate page numbers for pagination
function getPageNumbers(current: number, total: number): (number | '...')[] {
  const pages: (number | '...')[] = [];
  if (total <= 7) {
    for (let i = 1; i <= total; i++) pages.push(i);
  } else {
    pages.push(1);
    if (current > 3) pages.push('...');
    for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
      pages.push(i);
    }
    if (current < total - 2) pages.push('...');
    pages.push(total);
  }
  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
---

<BaseLayout title={fluidThemeConfig.site.title} description={fluidThemeConfig.site.description}>
  <!-- Banner — matching halo-theme-fluid banner.html -->
  <div class="header-inner" style={`height: ${fluidThemeConfig.banner.index_height};`}>
    <div id="banner" class="banner" style={fluidBannerStyle()} parallax={String(fluidThemeConfig.banner.parallax)}>
      <div class="full-bg-img">
        <div class="mask flex-center" style={fluidMaskStyle()}>
          <div class="banner-text text-center fade-in-up">
            <div class="h2" style="font-size: 32px; font-weight: 500; color: #fff; line-height: 1.2;">
              <span id="subtitle" data-typed-fallback={fluidThemeConfig.index.slogan.text}></span>
            </div>
          </div>
          <div class="scroll-down-bar" id="scroll-down-bar">
            <span class="scroll-down-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 5v14M19 12l-7 7-7-7"/>
              </svg>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Post List — matching halo-theme-fluid index.html structure -->
  <main>
    <div class="container nopadding-x-md">
      <div id="board" style="margin-top: 0">
        <div class="container">
          <div class="row">
            <div class="col-12 col-md-10 m-auto">
              {posts.map((post) => (
                <PostCard post={post} />
              ))}

              <!-- Pagination — matching halo-theme-fluid paginator -->
              {totalPages > 1 && (
                <nav class="pagination" aria-label="文章分页">
                  {pageNumbers.map((page) => (
                    page === '...' ? (
                      <span class="space">…</span>
                    ) : page === currentPage ? (
                      <span class="current">{page}</span>
                    ) : (
                      <a class="page-number" href={page === 1 ? '/' : `/page/${page}.html`}>{page}</a>
                    )
                  ))}
                  {currentPage < totalPages && (
                    <a class="extend next" rel="next" href="/page/2.html">›</a>
                  )}
                </nav>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  #subtitle {
    text-align: center;
  }
</style>

<script>
  // Banner parallax — matching halo-theme-fluid boot.js
  function initParallax() {
    const banner = document.getElementById('banner');
    if (!banner || banner.getAttribute('parallax') !== 'true') return;
    const board = document.getElementById('board');
    if (!board) return;

    function onScroll() {
      const marginTop = parseInt(getComputedStyle(board).marginTop, 10) || 0;
      const maxOffset = 96 + marginTop;
      const offset = Math.min(window.scrollY / 5, maxOffset);
      banner.style.transform = `translate3d(0, ${offset}px, 0)`;
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  initParallax();

  // Typed.js-style typing effect with Fluid's random Hitokoto/Jinrishici subtitle behavior.
  async function initTyped() {
    const el = document.getElementById('subtitle');
    if (!el) return;

    const fallback = el.getAttribute('data-typed-fallback') || '踏上取经路比取得真经更重要。';
    const text = await resolveRandomSubtitle(fallback);
    let charIndex = 0;

    function escapeHtml(value) {
      return value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderSubtitle(value) {
      const escaped = escapeHtml(value);
      const cursor = '<span class="typed-cursor typed-cursor--blink" aria-hidden="true">_</span>';
      return `${escaped}${cursor}`;
    }

    function type() {
      if (charIndex < text.length) {
        charIndex++;
        el.innerHTML = renderSubtitle(text.substring(0, charIndex));
        setTimeout(type, 100);
      }
      // Done typing — cursor keeps blinking via CSS animation
    }

    setTimeout(type, 1000);
  }

  initTyped();

  function withTimeout(promise, timeoutMs) {
    let timer;
    const timeout = new Promise((_, reject) => {
      timer = window.setTimeout(() => reject(new Error('subtitle request timeout')), timeoutMs);
    });

    return Promise.race([promise, timeout]).finally(() => {
      window.clearTimeout(timer);
    });
  }

  async function resolveRandomSubtitle(fallback) {
    const providers = Math.random() < 0.5
      ? [fetchHitokotoSubtitle, fetchJinrishiciSubtitle]
      : [fetchJinrishiciSubtitle, fetchHitokotoSubtitle];

    for (const provider of providers) {
      try {
        const sentence = await withTimeout(provider(), 3500);
        if (sentence) return sentence;
      } catch (error) {
        console.warn('[subtitle] failed to load random sentence', error);
      }
    }

    return fallback;
  }

  function formatSubtitle(sentence) {
    const cleanSentence = typeof sentence === 'string' ? sentence.trim() : '';
    return cleanSentence;
  }

  async function fetchHitokotoSubtitle() {
    const response = await fetch('https://v1.hitokoto.cn');
    if (!response.ok) throw new Error(`hitokoto request failed: ${response.status}`);
    const data = await response.json();
    return formatSubtitle(data.hitokoto);
  }

  function loadJinrishiciSdk() {
    if (window.jinrishici?.load) return Promise.resolve(window.jinrishici);

    return new Promise((resolve, reject) => {
      const existing = document.querySelector('script[data-jinrishici-sdk]');
      if (existing) {
        existing.addEventListener('load', () => resolve(window.jinrishici), { once: true });
        existing.addEventListener('error', reject, { once: true });
        return;
      }

      const script = document.createElement('script');
      script.src = 'https://sdk.jinrishici.com/v2/browser/jinrishici.js';
      script.async = true;
      script.dataset.jinrishiciSdk = 'true';
      script.onload = () => resolve(window.jinrishici);
      script.onerror = () => reject(new Error('jinrishici sdk failed to load'));
      document.head.appendChild(script);
    });
  }

  async function fetchJinrishiciSubtitle() {
    const jinrishici = await loadJinrishiciSdk();
    return new Promise((resolve, reject) => {
      if (!jinrishici?.load) {
        reject(new Error('jinrishici sdk unavailable'));
        return;
      }

      jinrishici.load((result) => {
        const sentence = result?.data?.content;
        resolve(formatSubtitle(sentence));
      });
    });
  }

  // Scroll down arrow click — matching halo-theme-fluid
  function initScrollDownArrow() {
    const scrollDownBar = document.getElementById('scroll-down-bar');
    if (scrollDownBar) {
      scrollDownBar.addEventListener('click', () => {
        const banner = document.getElementById('banner');
        if (banner) {
          window.scrollTo({ top: banner.offsetHeight, behavior: 'smooth' });
        }
      });
    }
  }

  initScrollDownArrow();
</script>
