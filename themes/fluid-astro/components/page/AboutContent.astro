---
import { fluidThemeConfig } from '../../config.mjs';

const { author } = fluidThemeConfig;
const zhihu = author.social?.zhihu;
const email = author.social?.email;
---

<div class="about-avatar">
  <img src={author.avatar} class="img-fluid" alt={author.name || 'avatar'} />
</div>

<div class="text-center">
  <div class="about-info">
    <div class="about-name">{author.name}</div>
    <div class="about-intro">{author.intro}</div>
    <div class="about-icons">
      {zhihu?.enable && zhihu.url && (
      <a class="about-icon about-icon-zhihu hint--bottom hint--rounded" target="_blank" rel="noopener" href={zhihu.url} aria-label={zhihu.label} title={zhihu.label}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4.6 5.4h7.7v2H9.1c-.1 1-.2 1.9-.4 2.8h4.1v2H8.2c-.6 2.1-1.7 4-3.1 5.7l-1.5-1.4c1.2-1.3 2-2.8 2.5-4.3H3.5v-2h3.1c.2-.9.4-1.8.5-2.8H4.6v-2Zm5.2 8.4c1.1 1 2.2 2.2 3.4 3.6l-1.6 1.4c-1-1.4-2.1-2.6-3.2-3.7l1.4-1.3Z" />
          <path d="M14.1 4.8h6.7v13.7h-6.7V4.8Zm2.1 2v9.7h2.5V6.8h-2.5Z" />
        </svg>
      </a>
      )}
      {email?.enable && email.url && (
      <a class="about-icon about-icon-email hint--bottom hint--rounded" target="_blank" rel="noopener" href={email.url} aria-label={email.label} title={email.label}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4.8 6.5h14.4c.9 0 1.6.7 1.6 1.6v7.8c0 .9-.7 1.6-1.6 1.6H4.8c-.9 0-1.6-.7-1.6-1.6V8.1c0-.9.7-1.6 1.6-1.6Zm.7 2 6.5 4.6 6.5-4.6h-13Zm13.3 1.8-6 4.2a1.4 1.4 0 0 1-1.6 0l-6-4.2v5.1h13.6v-5.1Z" />
        </svg>
      </a>
      )}
    </div>
  </div>
</div>

<article class="about-content page-content mt-5">
  <div class="markdown-body">
    <slot />
  </div>
</article>
