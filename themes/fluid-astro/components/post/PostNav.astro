---
// PostNav - previous/next post navigation at bottom of article

interface PostLink {
  title: string;
  abbrlink: string;
}

interface Props {
  prevPost?: PostLink;
  nextPost?: PostLink;
}

const { prevPost, nextPost } = Astro.props;
---

{(prevPost || nextPost) && (
  <div class="post-prevnext my-3" aria-label="文章导航">
    <article class="post-prev col-6">
      {prevPost && (
        <a href={`/posts/${prevPost.abbrlink}`} title={prevPost.title}>
          <svg class="post-nav-icon post-nav-icon-left" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M15 18l-6-6 6-6"></path>
          </svg>
          <span class="hidden-mobile">{prevPost.title}</span>
          <span class="visible-mobile">上一篇</span>
        </a>
      )}
    </article>
    <article class="post-next col-6">
      {nextPost && (
        <a href={`/posts/${nextPost.abbrlink}`} title={nextPost.title}>
          <span class="hidden-mobile">{nextPost.title}</span>
          <span class="visible-mobile">下一篇</span>
          <svg class="post-nav-icon post-nav-icon-right" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M9 18l6-6-6-6"></path>
          </svg>
        </a>
      )}
    </article>
  </div>
)}
