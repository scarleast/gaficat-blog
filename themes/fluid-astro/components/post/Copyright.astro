---
// Copyright notice - Fluid-style license box shown at bottom of posts
const siteUrl = 'https://www.gaficat.com';
const postUrl = `${siteUrl}${Astro.url.pathname}`;

interface Props {
  title?: string;
  author?: string;
  date?: Date;
}

const { title = '', author = 'scarleast', date } = Astro.props;
const formattedDate = date
  ? `${date.getFullYear()}年${String(date.getMonth() + 1).padStart(2, '0')}月${String(date.getDate()).padStart(2, '0')}日`
  : undefined;
---

<div class="license-box my-3">
  <div class="license-title">
    <div>{title}</div>
    <div>{postUrl}</div>
  </div>
  <div class="license-meta">
    <div class="license-meta-item">
      <div>作者</div>
      <div>{author}</div>
    </div>

    {formattedDate && (
      <div class="license-meta-item license-meta-date">
        <div>发布于</div>
        <div>{formattedDate}</div>
      </div>
    )}

    <div class="license-meta-item">
      <div>许可协议</div>
      <div>
        <a
          class="print-no-link"
          target="_blank"
          href="https://creativecommons.org/licenses/by-nc-nd/4.0/deed.zh"
          rel="external nofollow noreferrer"
          aria-label="BY - 署名"
          data-tooltip="署名"
        >
          <span class="license-badge" aria-hidden="true">BY</span>
        </a>
        <a
          class="print-no-link"
          target="_blank"
          href="https://creativecommons.org/licenses/by-nc-nd/4.0/deed.zh"
          rel="external nofollow noreferrer"
          aria-label="NC - 非商业性使用"
          data-tooltip="非商业性使用"
        >
          <span class="license-badge" aria-hidden="true">NC</span>
        </a>
        <a
          class="print-no-link"
          target="_blank"
          href="https://creativecommons.org/licenses/by-nc-nd/4.0/deed.zh"
          rel="external nofollow noreferrer"
          aria-label="ND - 禁止演绎"
          data-tooltip="禁止演绎"
        >
          <span class="license-badge" aria-hidden="true">ND</span>
        </a>
      </div>
    </div>
  </div>
  <div class="license-icon iconfont"></div>
</div>
