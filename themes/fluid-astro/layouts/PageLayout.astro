---
import BaseLayout from './BaseLayout.astro';
import { fluidBannerStyle, fluidMaskStyle, fluidThemeConfig } from '../config.mjs';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <!-- Banner with page title — matching halo-theme-fluid banner.html -->
  <div class="header-inner" style={`height: ${fluidThemeConfig.banner.page_height};`}>
    <div id="banner" class="banner" style={fluidBannerStyle()} parallax={String(fluidThemeConfig.banner.parallax)}>
      <div class="full-bg-img">
        <div class="mask flex-center" style={fluidMaskStyle()}>
          <div class="banner-text text-center fade-in-up">
            <div class="h2">
              <span id="subtitle">{title}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Page content — matching halo-theme-fluid board structure -->
  <main>
    <div class="container nopadding-x-md">
      <div id="board">
        <div class="container">
          <div class="row">
            <div class="col-12 col-md-10 m-auto">
              <slot />
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  function initParallax() {
    const banner = document.getElementById('banner');
    if (!banner || banner.getAttribute('parallax') !== 'true') return;
    const board = document.getElementById('board');
    if (!board) return;

    function onScroll() {
      const marginTop = parseInt(getComputedStyle(board).marginTop, 10) || 0;
      const maxOffset = 96 + marginTop;
      const offset = Math.min(window.scrollY / 5, maxOffset);
      banner.style.transform = `translate3d(0, ${offset}px, 0)`;
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  initParallax();
</script>
