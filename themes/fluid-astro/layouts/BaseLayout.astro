---
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ScrollTop from '../components/common/ScrollTop.astro';
import SearchModal from '../components/common/SearchModal.astro';
import PlyrInit from '../components/media/PlyrInit.astro';
import OpenGraph from '../components/seo/OpenGraph.astro';
import '../assets/styles/global.css';
import '../assets/styles/typography.css';
import { fluidThemeConfig } from '../config.mjs';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  image?: string;
  url?: string;
  publishedTime?: string;
}

const {
  title = fluidThemeConfig.site.title,
  description = fluidThemeConfig.site.description,
  type = 'website',
  image,
  url,
  publishedTime,
} = Astro.props;

const isHome = Astro.url.pathname === '/';
const defaultColorScheme = fluidThemeConfig.dark_mode.default;
const themeColor = fluidThemeConfig.color.theme_color[defaultColorScheme] || fluidThemeConfig.color.theme_color.dark;
---

<!doctype html>
<html lang={fluidThemeConfig.site.language} class={defaultColorScheme} data-default-color-scheme={defaultColorScheme} data-color-scheme={defaultColorScheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={themeColor} />

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const valid = { dark: true, light: true };
        const stored =
          localStorage.getItem('Fluid_Color_Scheme') ||
          localStorage.getItem('theme');
        const fallback = root.dataset.defaultColorScheme || 'dark';
        const scheme = valid[stored] ? stored : fallback;

        root.dataset.colorScheme = scheme;
        root.classList.toggle('dark', scheme === 'dark');
        root.classList.toggle('light', scheme === 'light');
        root.style.colorScheme = scheme;
      })();
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={fluidThemeConfig.feed.title} href="/rss.xml" />

    <!-- Fonts: JetBrains Mono for code only -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <OpenGraph
      title={title}
      description={description}
      type={type}
      image={image}
      url={url}
      publishedTime={publishedTime}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <ScrollTop />
    <SearchModal />
    <PlyrInit />
    <noscript>
      <div class="noscript-warning" style="background-color: #f55; color: #fff; font-family: sans-serif; font-size: 1rem; font-weight: bold; position: fixed; left: 0; bottom: 0; text-align: center; width: 100%; z-index: 99;">
        博客在允许 JavaScript 运行的环境下浏览效果更佳
      </div>
    </noscript>
  </body>
</html>
